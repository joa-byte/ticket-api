generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int    @id @default(autoincrement())
  email      String @unique
  username   String @unique
  name       String

  groups   UserGroup[]
  items    ItemUser[]
  payments TicketPayment[]
}

model Group {
  id   Int    @id @default(autoincrement())
  name String

  users   UserGroup[]
  tickets Ticket[]
}

model UserGroup {
  userId  Int
  groupId Int

  user  User  @relation(fields: [userId], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@id([userId, groupId])
}

model Ticket {
  id      Int @id @default(autoincrement())
  groupId Int

  state   TicketState @default(UPLOADED)

  group         Group                @relation(fields: [groupId], references: [id])
  items         Item[]
  payments      TicketPayment[]
  aiExtractions TicketAiExtraction[]
  files         File[]
} 

model File {
  id        String   @id @default(uuid())
  key       String
  url       String
  mimeType  String
  size      Int
  provider  String
  createdAt DateTime @default(now())

  ticketId Int?
  ticket   Ticket? @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
  @@map("files")
}

enum TicketState {
  UPLOADED
  AI_PROCESSED
  ITEMS_CONFIRMED
  CONSUMERS_CONFIRMED
  PAYERS_CONFIRMED
  SETTLED
  CANCELLED
}

model TicketAiExtraction {
  id       String @id @default(uuid())
  ticketId Int

  provider String
  model    String?

  rawResponse Json

  status AiExtractionStatus @default(SUCCESS)
  error  String?

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
}

enum AiExtractionStatus {
  SUCCESS
  FAILED
}

model Item {
  id       Int @id @default(autoincrement())
  ticketId Int
  price    Int // centavos
  quantity Float @default(1)

  ticket Ticket @relation(fields: [ticketId], references: [id])
  users  ItemUser[]
}

model ItemUser {
  itemId   Int
  userId   Int
  quantity Float @default(1)

  item Item @relation(fields: [itemId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@id([itemId, userId])
}

model TicketPayment {
  id       Int @id @default(autoincrement())
  ticketId Int
  userId   Int
  amount   Int // centavos

  ticket Ticket @relation(fields: [ticketId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}
